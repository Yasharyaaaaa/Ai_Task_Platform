# Root environment file consumed by docker-compose. Copy to `.env` and fill in.
# (Per-service .env.example files also exist under backend/ and worker/.)

# Secret used to sign JWTs. Use a long, random string in production.
JWT_SECRET=change_this_to_a_long_random_secret

# Anthropic Claude — required for AI task operations (used by the worker).
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5
