MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>
REDIS_URL=redis://localhost:6379

# Anthropic Claude — required for AI operations (summarize, rewrite, translate,
# keywords, sentiment, explain, custom). Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
# Optional: default model for AI operations when the task doesn't specify one.
ANTHROPIC_MODEL=claude-haiku-4-5

# Optional: max attempts before a failed task goes to the dead-letter queue.
MAX_TASK_ATTEMPTS=3
